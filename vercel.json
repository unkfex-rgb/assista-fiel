{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-builds",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_APP_TITLE": "Assista Fiel!",
    "VITE_APP_LOGO": "AF"
  }
}
